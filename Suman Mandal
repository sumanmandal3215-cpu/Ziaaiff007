<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zia AI - Pocket Option Expert</title>
    <style>
        body, html { margin: 0; padding: 0; height: 100%; overflow-x: hidden; background: #001219; font-family: 'Segoe UI', sans-serif; color: white; }
        .ocean { position: fixed; bottom: 0; width: 100%; height: 100%; z-index: -1; }
        .wave { position: absolute; bottom: -50px; width: 200%; height: 300px; background: rgba(0, 150, 199, 0.1); border-radius: 40%; animation: move 15s infinite linear; }
        @keyframes move { 0% { transform: translateX(0) rotate(0deg); } 100% { transform: translateX(-50%) rotate(360deg); } }
        
        /* Login Screen */
        #login-screen { position: fixed; inset: 0; background: #000; z-index: 3000; display: flex; flex-direction: column; justify-content: center; align-items: center; }
        .login-box { background: rgba(255,255,255,0.05); padding: 30px; border-radius: 20px; border: 1px solid #94d2bd; text-align: center; width: 85%; backdrop-filter: blur(10px); }
        input { width: 90%; padding: 12px; margin: 10px 0; border-radius: 10px; border: 1px solid #333; background: #111; color: #fff; }
        .login-btn { background: #94d2bd; color: #001219; padding: 12px 40px; border: none; border-radius: 25px; font-weight: bold; cursor: pointer; }
        
        /* Main UI */
        .app-container { display: none; padding: 20px; text-align: center; }
        .orb { width: 150px; height: 150px; background: radial-gradient(circle, #e9d8a6, #005f73, #0a9396); border-radius: 50%; margin: 50px auto; box-shadow: 0 0 50px #94d2bd; cursor: pointer; transition: 0.3s; }
        .active-orb { animation: vibrate 0.2s infinite; box-shadow: 0 0 80px #fff; border: 4px solid #fff; }
        @keyframes vibrate { 0% { transform: scale(1.1) translate(1px, 1px); } 50% { transform: scale(1.15) translate(-1px, -1px); } 100% { transform: scale(1.1) translate(1px, -1px); } }

        /* Menu & Buttons */
        .grid-menu { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 20px auto; max-width: 400px; }
        .action-btn { background: rgba(148, 210, 189, 0.1); border: 1px solid #94d2bd; padding: 15px; border-radius: 15px; color: #94d2bd; font-size: 14px; cursor: pointer; font-weight: bold; }
        .support-link { margin-top: 25px; display: inline-block; background: #ee9b00; color: #000; padding: 12px 25px; border-radius: 30px; font-weight: bold; text-decoration: none; box-shadow: 0 4px 15px rgba(238, 155, 0, 0.3); }
        
        /* Chat Input */
        .chat-input-area { position: fixed; bottom: 20px; width: 100%; display: none; justify-content: center; align-items: center; gap: 10px; }
        .round-btn { background: #e9d8a6; border: none; width: 55px; height: 55px; border-radius: 50%; font-size: 22px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        .text-box { width: 60%; background: rgba(255,255,255,0.1); border: 1px solid #444; padding: 15px; border-radius: 30px; color: white; outline: none; }
    </style>
</head>
<body>

    <div id="login-screen">
        <div class="login-box">
            <h2 style="color: #e9d8a6;">Zia AI Login</h2>
            <input type="text" id="userid" placeholder="User ID">
            <input type="password" id="pass" placeholder="Password">
            <button class="login-btn" onclick="handleLogin()">SIGN IN</button>
            <br><br>
            <a href="https://sumanmandal3215-cpu.github.io/Ziaai/" target="_blank" class="support-link">START AI SUPPORT</a>
        </div>
    </div>

    <div class="app-container" id="main-app">
        <div class="orb" id="ai-orb" onclick="startVoice()"></div>
        <h3 id="status-text" style="color: #94d2bd;">Zia is Online</h3>

        <div class="grid-menu">
            <button class="action-btn" onclick="ZiaTalk('profit')">Daily Profit Trick</button>
            <button class="action-btn" onclick="ZiaTalk('market')">Market Status (20+)</button>
            <button class="action-btn" onclick="ZiaTalk('withdraw')">How to Withdraw</button>
            <button class="action-btn" onclick="ZiaTalk('deposit')">How to Deposit</button>
        </div>
    </div>

    <div class="chat-input-area" id="input-bar">
        <button class="round-btn" onclick="startVoice()">🎤</button>
        <input type="text" id="chat-msg" class="text-box" placeholder="জিয়া-কে জিজ্ঞাসা করুন...">
        <button class="round-btn" onclick="sendMsg()">➤</button>
    </div>

    <div class="ocean"><div class="wave"></div></div>

    <script>
        const Recognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        const sr = Recognition ? new Recognition() : null;
        if(sr) sr.lang = 'bn-BD'; // বাংলা সাপোর্ট

        function handleLogin() {
            const user = document.getElementById('userid').value;
            const pass = document.getElementById('pass').value;
            if(user !== "" && pass !== "") {
                document.getElementById('login-screen').style.display = 'none';
                document.getElementById('main-app').style.display = 'block';
                document.getElementById('input-bar').style.display = 'flex';
                speak("স্বাগতম। আমি জিয়া। পকেট অপশন ট্রেডিংয়ে আমি আপনাকে কিভাবে সাহায্য করতে পারি?");
            } else {
                alert("দয়া করে আইডি এবং পাসওয়ার্ড দিন।");
            }
        }

        function speak(text) {
            window.speechSynthesis.cancel();
            const msg = new SpeechSynthesisUtterance(text);
            msg.lang = 'bn-BD';
            msg.pitch = 1.2; // নারীসুলভ কণ্ঠ
            msg.rate = 1.0;
            
            const orb = document.getElementById('ai-orb');
            msg.onstart = () => orb.classList.add('active-orb');
            msg.onend = () => orb.classList.remove('active-orb');
            window.speechSynthesis.speak(msg);
        }

        function startVoice() {
            if(!sr) return alert("আপনার ব্রাউজারে ভয়েস সাপোর্ট নেই।");
            sr.start();
            document.getElementById('status-text').innerText = "Listening...";
        }

        if(sr) {
            sr.onresult = (e) => {
                const text = e.results[0][0].transcript;
                document.getElementById('chat-msg').value = text;
                sendMsg();
            };
            sr.onend = () => document.getElementById('status-text').innerText = "Zia is Online";
        }

        function ZiaTalk(type) {
            if(type === 'profit') speak("আজকের প্রফিট ট্রিক হলো ওটিসি মার্কেটে সাপোর্ট এবং রেজিস্ট্যান্স লেভেল দেখে ট্রেড করা।");
            if(type === 'market') speak("আমি ২০টি মার্কেটের ডাটা চেক করছি। বর্তমানে ইউরো ইউএসডি এবং জিবিপি ইউএসডি ট্রেড করার জন্য ভালো।");
            if(type === 'withdraw') speak("উইথড্র করার জন্য আপনার প্রোফাইলে গিয়ে ফিন্যান্স সেকশনে যান এবং আপনার পেমেন্ট মেথড সিলেক্ট করে রিকোয়েস্ট দিন।");
            if(type === 'deposit') speak("ডিপোজিট করার জন্য বিন্যান্স পে বা টিআরসি টুয়েন্টি ব্যবহার করা সবচেয়ে নিরাপদ এবং দ্রুত।");
        }

        function sendMsg() {
            const val = document.getElementById('chat-msg').value;
            if(!val) return;
            speak("আমি আপনার প্রশ্নটি বুঝতে পেরেছি। দয়া করে অপেক্ষা করুন।");
            document.getElementById('chat-msg').value = "";
        }
    </script>
</body>
</html>
